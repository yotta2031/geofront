# PostgreSQL等等
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/geo_crm

# Redis / ClickHouse / Milvus（可选，后续扩展）
REDIS_URL=redis://127.0.0.1:6379
# CLICKHOUSE_URL=
# MILVUS_URL=

# LLM（可选，配置 LITELLM_BASE_URL 走统一网关）
# LITELLM_BASE_URL=http://localhost:4000
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=
# ZHIPU_API_KEY=
# QWEN_API_KEY=
# LANGFUSE_SECRET=

JWT_SECRET=your-jwt-secret-key-change-in-production
PORT=3001
NODE_ENV=development

# STATIC_DIR=../public
